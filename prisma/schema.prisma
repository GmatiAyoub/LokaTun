generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIF
  SUSPENDU
  BANNI
}

enum StatutAnnonce {
  ACTIVE
  INACTIVE
  SUPPRIMEE
}

model User {
  id            Int        @id @default(autoincrement())
  nom           String
  prenom        String
  email         String     @unique
  telephone     String     @unique
  motDePasse    String
  role          Role       @default(USER)
  statut        UserStatus @default(ACTIF)
  noteMoyenne   Float      @default(0)
  nbEvaluations Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  annonces      Annonce[]

  @@map("users")
}

model Annonce {
  id            Int           @id @default(autoincrement())
  titre         String
  description   String
  categorie     String
  prixParJour   Float
  localisation  String
  statut        StatutAnnonce @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  proprietaire   User          @relation(fields: [proprietaireId], references: [id])
  proprietaireId Int

  photos        Photo[]
  disponibilites Disponibilite[]

  @@map("annonces")
}

model Photo {
  id         Int     @id @default(autoincrement())
  url        String
  publicId   String
  annonceId  Int
  annonce    Annonce @relation(fields: [annonceId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model Disponibilite {
  id         Int      @id @default(autoincrement())
  dateDebut  DateTime
  dateFin    DateTime
  annonceId  Int
  annonce    Annonce  @relation(fields: [annonceId], references: [id], onDelete: Cascade)

  @@map("disponibilites")
}