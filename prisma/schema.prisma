generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIF
  SUSPENDU
  BANNI
}

enum StatutAnnonce {
  ACTIVE
  INACTIVE
  SUPPRIMEE
}

enum StatutReservation {
  EN_ATTENTE
  ACCEPTEE
  PAYEE
  COMMISSION_PAYEE
  REFUSEE
  ANNULEE
  TERMINEE
}
enum MethodePaiement {
  CASH
  CARTE
}

enum StatutLitige {
  NOUVEAU
  EN_COURS
  RESOLU
  FERME
}

model User {
  id            Int        @id @default(autoincrement())
  nom           String
  prenom        String
  email         String     @unique
  telephone     String     @unique
  motDePasse    String
  role          Role       @default(USER)
  statut        UserStatus @default(ACTIF)
  noteMoyenne   Float      @default(0)
  nbEvaluations Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  annonces               Annonce[]
  reservationsLocataire  Reservation[]  @relation("LocataireRelation")
  evaluationsDonnees     Evaluation[]   @relation("EvaluateurRelation")
  evaluationsRecues      Evaluation[]   @relation("EvalueRelation")
  litiges                Litige[]

  @@map("users")
}

model Annonce {
  id            Int           @id @default(autoincrement())
  titre         String
  description   String
  categorie     String
  prixParJour   Float
  localisation  String
  statut        StatutAnnonce @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  proprietaire   User          @relation(fields: [proprietaireId], references: [id])
  proprietaireId Int

  photos         Photo[]
  disponibilites Disponibilite[]
  reservations   Reservation[]

  @@map("annonces")
}

model Photo {
  id         Int     @id @default(autoincrement())
  url        String
  publicId   String
  annonceId  Int
  annonce    Annonce @relation(fields: [annonceId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model Disponibilite {
  id         Int      @id @default(autoincrement())
  dateDebut  DateTime
  dateFin    DateTime
  annonceId  Int
  annonce    Annonce  @relation(fields: [annonceId], references: [id], onDelete: Cascade)

  @@map("disponibilites")
}

model Reservation {
  id                     Int               @id @default(autoincrement())
  dateDebut              DateTime
  dateFin                DateTime
  montantBase            Float
  fraisLocataire         Float
  montantTotal           Float
  commissionProprietaire Float
  montantProprietaire    Float
  methodePaiement        MethodePaiement   @default(CASH)
  statut                 StatutReservation @default(EN_ATTENTE)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  locataire   User    @relation("LocataireRelation", fields: [locataireId], references: [id])
  locataireId Int

  annonce     Annonce @relation(fields: [annonceId], references: [id])
  annonceId   Int

  evaluations Evaluation[]
  litiges     Litige[]

  @@map("reservations")
}

model Evaluation {
  id          Int      @id @default(autoincrement())
  note        Int
  commentaire String?
  createdAt   DateTime @default(now())

  evaluateur    User @relation("EvaluateurRelation", fields: [evaluateurId], references: [id])
  evaluateurId  Int

  evalue        User @relation("EvalueRelation", fields: [evalueId], references: [id])
  evalueId      Int

  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId Int

  @@unique([evaluateurId, reservationId])
  @@map("evaluations")
}

model Litige {
  id            Int          @id @default(autoincrement())
  description   String
  photoUrl      String?
  statut        StatutLitige @default(NOUVEAU)
  resolution    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  signaleur     User        @relation(fields: [signaleurId], references: [id])
  signaleurId   Int

  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId Int

  @@map("litiges")
}